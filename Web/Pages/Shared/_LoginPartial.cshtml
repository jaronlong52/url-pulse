@using System.Security.Principal

<ul class="navbar-nav align-items-center">
  @if (User.Identity?.IsAuthenticated == true)
  {
    <li class="nav-item me-3">
      <span class="navbar-text text-dark">Hello, <strong>@User.Identity.Name</strong>!</span>
    </li>
    <li class="nav-item">
      <a class="btn btn-outline-danger px-3 rounded" asp-area="MicrosoftIdentity" asp-controller="Account"
        asp-action="SignOut">Sign out</a>
    </li>
  }
  else
  {
    <li class="nav-item">
      <a class="btn btn-primary px-4 rounded-pill" asp-area="MicrosoftIdentity" asp-controller="Account"
        asp-action="SignIn">Sign in</a>
    </li>
  }
</ul>