@page
@model IndexModel
@{
    ViewData["Title"] = "URL Pulse Dashboard";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary">URL Pulse</h1>
        <span class="badge bg-success">System Active</span>
    </div>

    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <h5 class="card-title mb-3">Add New Monitor</h5>
            <form method="post">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="InputUrl" class="form-label small fw-bold">Target URL</label>
                        <input asp-for="InputUrl" type="url"
                            class="form-control @(ViewData.ModelState.IsValid ? "" : "is-invalid")"
                            placeholder="https://example.com" required>
                        <span asp-validation-for="InputUrl" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-5">
                        <label asp-for="InputInterval" class="form-label small fw-bold">Check Interval (seconds)</label>
                        <input asp-for="InputInterval" type="number" class="form-control" placeholder="Default: 60"
                            min="10">
                    </div>

                    <div class="col-md-4">
                        <label asp-for="InputTimeout" class="form-label small fw-bold">Timeout (ms)</label>
                        <input asp-for="InputTimeout" type="number" class="form-control" placeholder="Default: 5000"
                            min="500">
                    </div>

                    <div class="col-md-3 d-grid align-items-end">
                        <button type="submit" class="btn btn-primary">Add Target</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 text-dark fw-bold">Active Monitors</h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Status</th>
                            <th>Target Information</th>
                            <th>Last Check</th>
                            <th>Response</th>
                            <th class="text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UrlMonitors.Any())
                        {
                            @foreach (var monitor in Model.UrlMonitors)
                            {
                                var latest = monitor.History
                                .OrderByDescending(h => h.CheckedAt)
                                .FirstOrDefault();

                                var isUp = latest != null &&
                                latest.StatusCode >= 200 &&
                                latest.StatusCode < 300;

                                <tr id="monitor-@monitor.Id">
                                    <td>
                                        <span class="badge rounded-pill bg-@(isUp ? "success" : "danger") px-3">
                                            @(isUp ? "UP" : "DOWN")
                                        </span>
                                    </td>

                                    <td>
                                        <div class="fw-bold text-dark">@monitor.Url</div>
                                        <div class="text-muted small">
                                            Interval: @(monitor.CheckIntervalSeconds)s |
                                            Timeout: @(monitor.TimeoutMs)ms
                                        </div>
                                    </td>

                                    <td>
                                        @if (latest != null)
                                        {
                                            <!-- Store UTC time in data attribute for JS to compute relative time -->
                                            <span class="last-checked" data-utc="@latest.CheckedAt.ToString("o")"
                                                title="@latest.CheckedAt.ToString("f")">
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Never</span>
                                        }
                                    </td>

                                    <td>
                                        @if (latest != null)
                                        {
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold @(isUp ? "text-success" : "text-danger")">
                                                    @(latest.LatencyMs) ms
                                                </span>
                                                <small class="text-muted">
                                                    Code: @latest.StatusCode
                                                </small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td class="text-end px-4">
                                        <form method="post" asp-page-handler="Delete"
                                            onsubmit="return confirm('Delete this monitor?');">
                                            <input type="hidden" name="id" value="@monitor.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-search display-4 d-block mb-3"></i>
                                    No monitors configured.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function computeRelativeTime(utc) {
        const checkedTime = new Date(utc);
        const now = new Date();
        const diffMinutes = Math.floor((now - checkedTime) / 60000);

        return diffMinutes <= 0
            ? "Just now"
            : diffMinutes + " minutes ago";
    }

    function updateRelativeTimes() {
        document.querySelectorAll(".last-checked").forEach(el => {
            const utc = el.dataset.utc;
            if (!utc) return;
            el.textContent = computeRelativeTime(utc);
        });
    }

    async function refreshMonitors() {
        const response = await fetch('?handler=Monitors');
        const monitors = await response.json();

        const rows = document.querySelectorAll("tbody tr");

        monitors.forEach(monitor => {
            const row = document.getElementById(`monitor-${monitor.id}`);
            if (!row) return;

            const isUp = monitor.latest &&
                monitor.latest.statusCode >= 200 &&
                monitor.latest.statusCode < 300;

            row.querySelector(".badge").className =
                `badge rounded-pill px-3 ${isUp ? "bg-success" : "bg-danger"}`;

            row.querySelector(".badge").textContent =
                isUp ? "UP" : "DOWN";

            if (monitor.latest) {
                const lastChecked = row.querySelector(".last-checked");
                lastChecked.dataset.utc = monitor.latest.checkedAt;
                lastChecked.textContent =
                    computeRelativeTime(monitor.latest.checkedAt);

                const latencyEl = row.querySelector(".fw-bold");
                latencyEl.textContent =
                    monitor.latest.latencyMs + " ms";
                latencyEl.className =
                    `fw-bold ${isUp ? "text-success" : "text-danger"}`;

                row.querySelector("small").textContent =
                    "Code: " + monitor.latest.statusCode;
            }
        });
    }

    updateRelativeTimes();
    setInterval(updateRelativeTimes, 30000);
    setInterval(refreshMonitors, 60000);
</script>